rules_version = '2';

/**
 * Falaah Application Security Rules - Prototipe Terbuka
 * 
 * Aturan ini dirancang untuk memudahkan pengembangan prototipe dengan mengizinkan
 * akses baca dan tulis ke seluruh dokumen bagi pengguna yang sudah terautentikasi.
 * Ini akan memperbaiki masalah "Missing or insufficient permissions" pada query
 * global (Collection Group) yang digunakan oleh Ustadz dan Wali.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // Izinkan semua akses baca/tulis jika pengguna sudah masuk (authenticated)
    // Ini mencakup query koleksi langsung maupun Collection Group.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Catatan: Untuk produksi, aturan ini harus diperketat berdasarkan peran (RBAC)
    // dan kepemilikan dokumen untuk keamanan data yang lebih baik.
  }
}