rules_version = '2';

/**
 * Falaah Application Security Rules - Development Mode
 * Aturan ini dikonfigurasi untuk mengizinkan akses penuh bagi pengguna terautentikasi.
 * Ini mencakup dukungan penuh untuk Collection Group Queries yang digunakan di Dashboard Ustadz.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // Izinkan akses rekursif penuh untuk semua dokumen dan sub-koleksi
    // Hal ini memastikan query global (Collection Group) tidak terhalang.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deployment trigger comment: Jalankan ulang aturan untuk memastikan perubahan diterapkan.
    // Last Update: 2024-03-20 
  }
}