rules_version = '2';

/**
 * Aturan Keamanan Falaah - Perbaikan Menyeluruh
 * Mengizinkan akses penuh bagi pengguna yang sudah login (termasuk anonim).
 * Aturan ini mencakup standar query dan Collection Group query.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // IZIN UTAMA: Izinkan baca dan tulis di seluruh tingkat dokumen
    // asalkan request berasal dari pengguna yang terautentikasi.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Deployment ID: REFRESH_PERMISSION_V2_2024
  }
}