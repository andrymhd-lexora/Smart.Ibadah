rules_version = '2';

/**
 * Falaah Application Security Rules - Prototipe Terbuka
 * Aturan ini disederhanakan untuk memastikan aliran data antara Santri dan Ustadz lancar.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Izinkan Collection Group Query untuk hafalanSubmissions
    // Sangat penting agar Ustadz bisa melihat setoran dari semua path santri.
    match /{path=**}/hafalanSubmissions/{id} {
      allow read, write: if request.auth != null;
    }

    // 2. Aturan Global untuk semua dokumen
    // Mengizinkan baca/tulis jika pengguna sudah terautentikasi (Anonymous/Email).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}